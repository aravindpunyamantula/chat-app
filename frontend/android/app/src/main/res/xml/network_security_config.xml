<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!--
        DEV ONLY: allow plain HTTP to your local backend.
        10.0.2.2 = Android emulator → host machine.
        Add your LAN IP here too if testing on a real device (e.g. 192.168.x.x).
        Remove this block entirely for a production HTTPS backend.
    -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">10.0.2.2</domain>
        <domain includeSubdomains="false">localhost</domain>
    </domain-config>

    <!-- All other traffic: HTTPS only -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system"/>
        </trust-anchors>
    </base-config>
</network-security-config>
